{
	"name": "@p-f-design/shell",
	"version": "1.0.0",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "restricted"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/p-f-design/p-f-design.git"
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"peerDependencies": {
		"@emotion/react": ">=11",
		"@emotion/styled": ">=11",
		"@mui/icons-material": ">=7",
		"@mui/material": ">=7",
		"@p-f-design/styles": ">=1",
		"react": ">=18",
		"react-dom": ">=18",
		"react-router": ">=7"
	},
	"devDependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^7.3.8",
		"@mui/material": "^7.3.8",
		"@mui/system": "^7.3.8",
		"@p-f-design/styles": "workspace:*",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.10.1",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3"
	}
}
