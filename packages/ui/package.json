{
	"name": "@p-f-design/ui",
	"version": "1.0.0",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "restricted"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/p-f-design/p-f-design.git"
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"storybook:test": "test-storybook",
		"coverage:storybook": "test-storybook --coverage"
	},
	"peerDependencies": {
		"@emotion/react": ">=11",
		"@emotion/styled": ">=11",
		"@mui/icons-material": ">=7",
		"@mui/material": ">=7",
		"@p-f-design/styles": ">=1",
		"@tanstack/react-table": ">=8",
		"react": ">=18",
		"react-dom": ">=18"
	},
	"devDependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@fontsource/material-icons": "^5.2.7",
		"@fontsource/public-sans": "^5.2.7",
		"@mui/icons-material": "^7.3.8",
		"@mui/material": "^7.3.8",
		"@mui/system": "^7.3.8",
		"@p-f-design/styles": "workspace:*",
		"@storybook/addon-a11y": "^10.2.8",
		"@storybook/addon-coverage": "^3.0.0",
		"@storybook/addon-docs": "^10.2.8",
		"@storybook/addon-themes": "^10.2.8",
		"@storybook/react": "^10.2.8",
		"@storybook/test-runner": "^0.24.2",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/table-core": "^8.21.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"dayjs": "^1.11.19",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"storybook": "^10.2.8",
		"storybook-react-rsbuild": "^3.2.2",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3"
	}
}
