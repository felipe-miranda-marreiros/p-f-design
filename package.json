{
	"name": "p-f-design",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter @p-f-design/web dev",
		"build": "turbo run build",
		"build:packages": "turbo run build --filter=\"./packages/**\"",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"clean": "turbo run clean",
		"storybook": "pnpm --filter @p-f-design/ui storybook",
		"build-storybook": "turbo run build-storybook --filter=@p-f-design/ui",
		"storybook:test": "pnpm --filter @p-f-design/ui storybook:test",
		"coverage:storybook": "pnpm --filter @p-f-design/ui coverage:storybook",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"lefthook": "^2.1.1",
		"semantic-release": "^24.0.0",
		"@semantic-release/changelog": "^6.0.0",
		"@semantic-release/git": "^10.0.0",
		"turbo": "^2.5.0",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
