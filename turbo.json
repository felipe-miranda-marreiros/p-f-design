{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "!**/*.stories.{tsx,jsx,mdx}", "!**/*.mdx"],
			"outputs": ["dist/**"]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "tsconfig.json"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "tsconfig.json", "vitest.config.ts"],
			"outputs": []
		},
		"clean": {
			"cache": false
		}
	}
}
